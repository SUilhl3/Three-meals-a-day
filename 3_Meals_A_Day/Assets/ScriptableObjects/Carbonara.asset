%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3a5d0d48200c4094894f6c9ffc07a6dc, type: 3}
  m_Name: Carbonara
  m_EditorClassIdentifier: Assembly-CSharp::Recipe
  recipeName: Carbonara
  steps: 12
  stepsList:
  - stepName: Get the yolks
    instructions: Break two eggs and gather the yolks and place them in a bowl.
    ingredient: 2 Eggs
    utensil: Bowl
    ingredientNeeded: {fileID: 4077141521328887635, guid: 26dd2342357dc454bb29148a4339dd1d, type: 3}
    station: Mixing
  - stepName: Greate Cheese
    instructions: Grab your cheese grater and grate the cheese
    ingredient: Grated Cheese
    utensil: Bowl (with yolks), Cheese Grater
    ingredientNeeded: {fileID: 4190418278369641638, guid: 2a3b3e8ccb1f2b14eb1a5e0939d9f427, type: 3}
    station: Mixing
  - stepName: Add black pepper
    instructions: Pour black pepper into the bowl
    ingredient: Black pepper
    utensil: jar of pepper
    ingredientNeeded: {fileID: 8254872087405063217, guid: 5cd1346ef5550044089c8b0faa74fed2, type: 3}
    station: Mixing
  - stepName: Mix to make cheese sauce
    instructions: Mix them together
    ingredient: Cheese mix
    utensil: Whisk
    ingredientNeeded: {fileID: 4981044970480557342, guid: 29a3889f6d2346e4a822dfb461709c3b, type: 3}
    station: Mixing
  - stepName: Cut meat
    instructions: Cut the selected meat into cubes
    ingredient: Meat
    utensil: Knife
    ingredientNeeded: {fileID: 3485377139243320888, guid: 96c31d99e8d69a04b9eb26a5942a33c2, type: 3}
    station: Cutting
  - stepName: Place the meat in a pan
    instructions: Place the cute meat into a pan and cook till it changes color.
    ingredient: Cut meat
    utensil: pan
    ingredientNeeded: {fileID: 279413600480192909, guid: 64b901fcfe9c2794598fd06f25337425, type: 3}
    station: Stove (pan)
  - stepName: Pour water into the pot
    instructions: Pour water into the pot and wait for it to boil
    ingredient: Water
    utensil: Pot
    ingredientNeeded: {fileID: 7081510691004027421, guid: 15a971dac45aa6b4ba1d682c3ba2ab07, type: 3}
    station: Stove (pot)
  - stepName: Place Noodles in pot
    instructions: Place the noodles and stir occasionally until cooked
    ingredient: Noodles
    utensil: Spoon
    ingredientNeeded: {fileID: 919132149155446097, guid: a0a047dba0e13414d8c10b9faad919ff, type: 3}
    station: Stove (pot)
  - stepName: Gather Pasta Water
    instructions: Gather Pasta Water
    ingredient: Pasta Water
    utensil: Bottle
    ingredientNeeded: {fileID: 3187056079399412273, guid: 298dbbf6d80b29f4c981d93fe1533e4e, type: 3}
    station: Stove (pot)
  - stepName: Collect Pasta
    instructions: Collect cooked pasta.
    ingredient: cooked pasta
    utensil: Bowl and spoon
    ingredientNeeded: {fileID: 5739929957827735761, guid: 72227be21c5f7134b9981ba12139dc62, type: 3}
    station: Stove (pot)
  - stepName: Place Pasta in the Pan with Cooked Meat
    instructions: Place Pasta into the Pan
    ingredient: Cooked Pasta
    utensil: pan
    ingredientNeeded: {fileID: 0}
    station: Stove (pan)
  - stepName: Place Pasta Water in the Pan
    instructions: Place the pasta water into the pan
    ingredient: Pasta water
    utensil: pan and pitcher
    ingredientNeeded: {fileID: 3187056079399412273, guid: 298dbbf6d80b29f4c981d93fe1533e4e, type: 3}
    station: Stove (pan)
  - stepName: Mix Time
    instructions: Mix the pan till spreaded evenly
    ingredient: mixed pasta and meat
    utensil: spoon
    ingredientNeeded: {fileID: 0}
    station: Stove (pan)
  - stepName: Pour the Cheese
    instructions: Grab the Cheese sauce adn add it into the pan
    ingredient: Cheese sauce
    utensil: bowl
    ingredientNeeded: {fileID: 4981044970480557342, guid: 29a3889f6d2346e4a822dfb461709c3b, type: 3}
    station: Stove (pan)
  - stepName: Mix them together
    instructions: Mix them together.
    ingredient: Cheese sauce and mixed pasta and meat
    utensil: spoon
    ingredientNeeded: {fileID: 0}
    station: Stove (pan)
  - stepName: Plate the meal!
    instructions: Bring the pot to the plate and serve
    ingredient: almost carbonara
    utensil: pan
    ingredientNeeded: {fileID: 0}
    station: Serving
